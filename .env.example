# Copie este arquivo para .env.local e preencha com suas credenciais
# Supabase: Painel do projeto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=bh@banhodebrilho.com.br

# ZapSign (assinatura digital): app.zapsign.com.br > Configurações > API
ZAPSIGN_API_TOKEN=

# URL da aplicação (em produção, a URL da Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000
